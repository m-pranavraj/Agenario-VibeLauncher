{
  "version": 2,
  "buildCommand": "pnpm install --frozen-lockfile && pnpm -w run build:vercel",
  "outputDirectory": "artifacts/agenario/dist",
  "functions": {
    "api/handler.mjs": {
      "maxDuration": 60,
      "memory": 1024,
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/handler" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
