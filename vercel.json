{
  "version": 2,
  "framework": null,
  "installCommand": "pnpm install --no-frozen-lockfile",
  "buildCommand": "pnpm -w run build:vercel",
  "outputDirectory": "dist",
  "builds": [
    {
      "src": "api/ping.mjs",
      "use": "@vercel/node"
    },
    {
      "src": "api/handler.mjs",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 60,
        "memory": 1024,
        "runtime": "nodejs20.x",
        "includeFiles": [
          "artifacts/api-server/**",
          "api/pino-worker.mjs",
          "api/pino-file.mjs",
          "api/pino-pretty.mjs",
          "api/thread-stream-worker.mjs"
        ]
      }
    }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/handler" },
    { "source": "/api/(.*)", "destination": "/api/handler" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
