{
  "name": "combined-semantic-graph",
  "version": "2.0.0",
  "description": "10-Dimension Code Analysis: CFG, modules, routes, calls, infra security, resilience, observability, cognitive complexity, architecture smells, dependency decay",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "csg": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "demo": "node --loader ts-node/esm test/demo.ts",
    "demo:full": "npx tsx test/demo-agenario-full.ts",
    "cli": "npx tsx src/cli.ts",
    "agenario": "npx tsx src/cli.ts agenario --src",
    "serve": "npx tsx src/server.ts",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@babel/generator": "^7.24.0",
    "@babel/parser": "^7.24.0",
    "@babel/traverse": "^7.24.0",
    "@babel/types": "^7.24.0",
    "commander": "^15.0.0"
  },
  "devDependencies": {
    "@types/babel__generator": "^7.6.0",
    "@types/babel__traverse": "^7.20.0",
    "@types/node": "^20.11.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.9"
  }
}
