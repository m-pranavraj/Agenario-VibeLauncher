    "@types/express-session": "^1.18.1",
    "@types/node": "catalog:",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.11.13",
    "esbuild": "0.27.3",
