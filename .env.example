# Database
DATABASE_URL=postgresql://user:password@host:5432/agenario

# Auth
SESSION_SECRET=generate-with-openssl-rand-hex-32

# AI Providers (at least one required)
GROQ_API_KEY=gsk_your_key_here
GROQ_KEYS=key1,key2  # optional, for key rotation

# Optional AI Provider Fallbacks (in order: OpenRouter > Groq > Cerebras > Anthropic > OpenAI)
OPENROUTER_API_KEY=sk-or-v1-your-key
CEREBRAS_API_KEY=your-cerebras-key
ANTHROPIC_API_KEY=sk-ant-your-key
ANTHROPIC_KEYS=key1,key2
OPENAI_API_KEY=sk-your-key
OPENAI_KEYS=key1,key2

# Payment (Razorpay)
RAZORPAY_KEY_ID=rzp_live_your_key
RAZORPAY_KEY_SECRET=your_secret

# Payment (Paddle)
PADDLE_API_KEY=your_api_key
PADDLE_WEBHOOK_SECRET=your_webhook_secret
PADDLE_ENVIRONMENT=sandbox
PADDLE_CREATOR_PRICE_ID=pri_xxxxxxxxxxxxxxxx

# App
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
APP_URL=http://localhost:5000
ADMIN_EMAIL=admin@agenario.tech

# Email (optional — for OTP & notifications)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-pass
SMTP_FROM=noreply@agenario.tech
EMAIL_ENABLED=false

# Monitoring
PULSE_SECRET=your-pulse-secret
LOG_LEVEL=debug
